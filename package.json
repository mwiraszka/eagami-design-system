{
  "name": "@eagami/ui",
  "version": "0.9.0",
  "description": "Lightweight, accessible Angular UI component library built on CSS custom properties",
  "author": "Michal Wiraszka <michal@eagami.com>",
  "license": "MIT",
  "keywords": [
    "angular",
    "ui",
    "component-library",
    "design-system",
    "accessible"
  ],
  "homepage": "https://github.com/mwiraszka/eagami-design-system#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/mwiraszka/eagami-design-system.git"
  },
  "bugs": {
    "url": "https://github.com/mwiraszka/eagami-design-system/issues"
  },
  "sideEffects": false,
  "scripts": {
    "ng": "ng",
    "sandbox": "ng serve sandbox -o",
    "build": "ng build eagami-ui && node scripts/clean-dist-package.mjs",
    "watch": "ng build eagami-ui --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write \"src/**\" \"sandbox/**\"",
    "lint": "eslint 'src/**'",
    "storybook": "ng run eagami-ui:storybook",
    "build-storybook": "ng run eagami-ui:build-storybook",
    "publish:lib": "pnpm build && pnpm publish dist/eagami-ui --no-git-checks --access public",
    "screenshots": "node scripts/screenshots.mjs"
  },
  "peerDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "0.2102.7",
    "@angular-devkit/build-angular": "21.2.7",
    "@angular-devkit/core": "21.2.7",
    "@angular/build": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/common": "21.2.8",
    "@angular/compiler": "21.2.8",
    "@angular/compiler-cli": "21.2.8",
    "@angular/core": "21.2.8",
    "@angular/forms": "21.2.8",
    "@angular/platform-browser": "21.2.8",
    "@angular/platform-browser-dynamic": "21.2.8",
    "@angular/router": "21.2.8",
    "@compodoc/compodoc": "1.2.1",
    "@eslint/js": "10.0.1",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/angular": "10.3.5",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-storybook": "10.3.5",
    "globals": "17.4.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-preset-angular": "16.1.4",
    "ng-packagr": "21.2.2",
    "prettier": "3.8.2",
    "puppeteer": "^24.40.0",
    "rxjs": "7.8.2",
    "storybook": "10.3.5",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1",
    "zone.js": "0.16.1"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "less",
      "lmdb",
      "msgpackr-extract",
      "unrs-resolver"
    ],
    "overrides": {
      "@hono/node-server": ">=1.19.13",
      "basic-ftp": ">=5.2.2",
      "brace-expansion@1": "1.1.13",
      "brace-expansion@2": "2.0.3",
      "brace-expansion@>=4": "5.0.5",
      "esbuild": "0.27.3",
      "handlebars": ">=4.7.9",
      "hono": ">=4.12.12",
      "lodash": ">=4.18.1",
      "lodash-es": ">=4.18.1",
      "picomatch": ">=4.0.4",
      "serialize-javascript": ">=7.0.5",
      "undici": ">=7.24.0",
      "webpack": "5.105.4"
    },
    "auditConfig": {
      "ignoreCves": [
        "CVE-2025-69873",
        "CVE-2026-4923",
        "CVE-2026-4926"
      ]
    }
  }
}
