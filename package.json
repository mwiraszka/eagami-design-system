{
  "name": "@eagami/ui",
  "description": "Lightweight, accessible Angular UI component library built on CSS custom properties",
  "author": "Michal Wiraszka",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve sandbox -o",
    "sandbox": "ng serve sandbox -o",
    "build": "ng build eagami-ui",
    "watch": "ng build eagami-ui --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint 'src/**'",
    "storybook": "ng run eagami-ui:storybook",
    "build-storybook": "ng run eagami-ui:build-storybook",
    "publish:lib": "ng build eagami-ui && pnpm publish dist/eagami-ui --no-git-checks --access public"
  },
  "dependencies": {
    "@angular/common": "21.2.1",
