    "@angular/core": "21.2.1",
    "@angular/forms": "21.2.1",
    "@angular/platform-browser": "21.2.1",
    "@angular/platform-browser-dynamic": "21.2.1",
    "@angular/router": "21.2.1",
    "rxjs": "7.8.2",
    "tslib": "2.3.0",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/architect": "0.2102.1",
    "@angular-devkit/build-angular": "21.2.1",
    "@angular-devkit/core": "21.2.1",
    "@angular/build": "21.2.1",
    "@angular/cli": "21.2.1",
    "@angular/compiler-cli": "21.2.1",
    "@compodoc/compodoc": "1.2.1",
    "@eslint/js": "10.0.1",
    "@storybook/addon-docs": "10.2.16",
    "@storybook/angular": "10.2.16",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/jest": "30.0.0",
    "@types/node": "25.0.0",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-storybook": "10.2.16",
    "globals": "17.4.0",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "jest-preset-angular": "16.1.1",
    "ng-packagr": "21.2.0",
    "prettier": "3.8.1",
    "storybook": "10.2.16",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
